  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out/extension",
    "rootDir": "src/extension",
    "lib": ["ES2020"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/extension/**/*.ts"]
}
