{
  "name": "geojson-edit",
  "displayName": "GeoJSON Edit (offline)",
  "description": "Offline / air-gapped GeoJSON editor with an embedded PMTiles basemap",
  "version": "0.0.1",
  "publisher": "local",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "geojson-edit.editor",
        "displayName": "GeoJSON Map Editor",
        "selector": [
          {
            "filenamePattern": "*.geojson"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "build:webview": "vite build",
    "build:ext": "tsc -p ./tsconfig.json",
    "build": "npm run build:webview && npm run build:ext",
    "typecheck:webview": "tsc -p ./tsconfig.webview.json",
    "watch:ext": "tsc -w -p ./tsconfig.json"
  },
  "dependencies": {
    "ol": "^10.3.1",
    "pmtiles": "^3.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  }
}
